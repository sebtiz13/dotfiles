#!/usr/bin/env bash
# ? Install packages with specific package manager
# shellcheck shell=bash
# {{ template "scripts-library" }}

set -eufo pipefail

{{ if eq .chezmoi.os "linux" -}}
  {{ if eq .chezmoi.osRelease.id "manjaro" -}}
  info "Pamac installing packages"

  # Enable AUR on pamac
  sudo sed -Ei '/EnableAUR/s/^#//' /etc/pamac.conf

  log 'Update PAMAC'
  sudo pamac update --no-confirm

  log 'Install packages with PAMAC'
  sudo pamac install --no-confirm {{ .packages.manjaro | join " " }}
  success "Pamac Successfully"
  {{ end -}}
{{ else if eq .chezmoi.os "darwin" -}}
log 'Install packages with Brew'

if ! command -v brew &> /dev/null; then
  info "Install brew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

info "Disable brew analytics"
brew analytics off

brew bundle --file=/dev/stdin <<EOF
{{ range (.packages.darwin.brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end }}
{{ range (.packages.darwin.casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end }}
EOF
{{ else -}}
info "System not supported, packages installation skipped"
{{ end -}}
