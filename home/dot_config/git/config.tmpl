[user]
	name = {{ .git.name }}
	email = {{ .git.email }}
	signingkey = {{ .git.signingkey }}
[commit]
	gpgsign = true
[tag]
	gpgSign = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictStyle = zdiff3
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
[pager]
	tag = sort -V
	format-patch = cat
	log = less
	reflog = less
	config = bat -pplproperties
	remote = bat -ppltsv
	ls-files = parallel eza --color=always --icons
	check-ignore = parallel eza --color=always --icons
[init]
	defaultBranch = main
[alias]
	ammend = commit --amend
  fixup = commit --fixup
